# Qdrant modes: local (default), memory, docker
QDRANT_MODE=local
# QDRANT_URL=http://127.0.0.1:6333

# LLM provider selection: openai, groq, or ollama
# LLM_PROVIDER=ollama

# Optional OpenAI config for answer generation in /api/query
# OPENAI_API_KEY=your_api_key
# OPENAI_MODEL=gpt-4o-mini

# Optional Groq config for answer generation in /api/query
# GROQ_API_KEY=your_groq_api_key
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional PostgreSQL DSN for call graph persistence
# POSTGRES_DSN=postgresql://user:password@localhost:5432/ragdb

