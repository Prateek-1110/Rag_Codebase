# Qdrant modes: local (default, runs in-process using local directory), memory, docker
QDRANT_MODE=local
# QDRANT_URL=http://127.0.0.1:6333

# LLM provider selection: openrouter or ollama
LLM_PROVIDER=openrouter

# OpenRouter Configuration for Answer Generation & Intent Classification
# Required: YES
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# OpenRouter Embedding Configuration
# Required: YES (used to embed codebase chunks for vector retrieval)
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# PostgreSQL DSN for call graph persistence & AST relationships
# Required: YES (see instructions on how to obtain this link in RAG setup docs)
POSTGRES_DSN=postgresql://user:password@localhost:5432/ragdb
